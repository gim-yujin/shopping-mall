<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="shopping-mall-rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/schema/ruleset_2_0_0.xsd">
    <description>Shopping Mall 프로젝트 PMD 핵심 규칙셋(점진적 확대 전제)</description>

    <!--
      초기 단계에서는 NPE/자원 누수/심각한 버그 가능성 중심으로 최소 규칙만 적용한다.
      스타일성 노이즈 규칙은 제외하고, 팀 합의 후 단계적으로 확장한다.
      - LocalVariableCouldBeFinal
      - MethodArgumentCouldBeFinal
    -->

    <!-- Null 관련 잠재 버그 -->
    <rule ref="category/java/errorprone.xml/NullAssignment"/>
    <rule ref="category/java/errorprone.xml/BrokenNullCheck"/>
    <rule ref="category/java/errorprone.xml/MisplacedNullCheck"/>
    <rule ref="category/java/errorprone.xml/UnusedNullCheckInEquals"/>

    <!-- 자원 누수 / 자원 관리 -->
    <rule ref="category/java/errorprone.xml/CloseResource"/>
    <rule ref="category/java/errorprone.xml/CheckSkipResult"/>

    <!-- 심각한 버그성 패턴 -->
    <rule ref="category/java/errorprone.xml/AssignmentInOperand"/>
    <rule ref="category/java/errorprone.xml/ReturnFromFinallyBlock"/>
    <rule ref="category/java/errorprone.xml/DoNotCallGarbageCollectionExplicitly"/>

    <!--
      Spring Data JPA 파생 쿼리 메서드는 연관 경로 탐색 표현을 위해 '_'를 사용한다.
      예: findByUserIdAndProduct_ProductId
      위 패턴은 MethodNamingConventions 기본 camelCase 정규식과 충돌하므로,
      repository 레이어에서 사용되는 파생 쿼리 네이밍에 한해 예외 처리한다.
      서비스/일반 클래스의 메서드 네이밍 규칙은 그대로 유지한다.
    -->
    <rule ref="category/java/codestyle.xml/MethodNamingConventions">
        <properties>
            <property name="violationSuppressRegex"
                      value=".*\b(find|read|get|query|count|exists|delete|remove)By\w+_\w+.*"/>
        </properties>
    </rule>
</ruleset>
